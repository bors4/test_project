{
  "name": "test_project",
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/js": "^9.39.3",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@wdio/allure-reporter": "^9.23.2",
    "@wdio/cli": "^9.23.2",
    "@wdio/cucumber-framework": "^9.23.2",
    "@wdio/devtools-service": "^10.2.1",
    "@wdio/local-runner": "^9.23.2",
    "@wdio/spec-reporter": "^9.23.2",
    "@wdio/types": "^9.23.2",
    "@wdio/visual-service": "^9.1.3",
    "allure": "^3.3.1",
    "chromedriver": "^146.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cucumber": "^2.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jsdoc": "^4.0.5",
    "minami": "^1.2.3",
    "npm-force-resolutions": "^0.0.10",
    "prettier": "^3.8.1",
    "taffydb": "^2.7.3",
    "wdio-video-reporter": "^6.2.0",
    "webdriverio": "^9.23.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chai": "^6.2.2",
    "mcp-server-commands": "^0.7.4"
  },
  "scripts": {
    "test": "cross-env HEADLESS=true RECORD_VIDEO=false DEBUG_MODE=false wdio run ./wdio.conf-ci.js",
    "test:debug": "cross-env HEADLESS=false RECORD_VIDEO=false DEBUG_MODE=true wdio run ./wdio.conf.js",
    "test:video": "cross-env HEADLESS=true RECORD_VIDEO=true DEBUG_MODE=false wdio run ./wdio.conf.js",
    "test:debug:video": "cross-env HEADLESS=false RECORD_VIDEO=true DEBUG_MODE=true wdio run ./wdio.conf.js",
    "test:feature": "cross-env HEADLESS=false RECORD_VIDEO=true wdio run ./wdio.conf-ci.js --spec",
    "test:tags": "cross-env HEADLESS=false RECORD_VIDEO=true wdio run ./wdio.conf.js --spec",
    "test-ci:browser": "cross-env HEADLESS=true wdio run ./wdio.conf-ci.js",
    "test-ci:mobile": "cross-env HEADLESS=false DEVICE=mobile CUCUMBER_TAGS='@mobile' wdio run ./wdio.conf-ci.js",
    "format": "prettier --write ./",
    "lint": "eslint ./src",
    "lint:write": "eslint --debug src/ --fix",
    "prettier": "prettier --write src/**/*.js",
    "allure:watch": "npx allure watch allure-results",
    "allure:generate": "npx allure generate allure-results -o allure-report/awesome",
    "allure:open": "npx allure open allure-report/awesome",
    "allure:history": "npx allure history allure-results -o allure-report/awesome",
    "allure:generate:history": "if exist allure-report\\awesome\\history (xcopy /E /I allure-report\\awesome\\history allure-results\\history /Y) & npx allure generate allure-results -o allure-report/awesome --report-name=\"Allure Report\"",
    "rag:index": "cd rag && node index.js",
    "rag:query": "cd rag && node query.js",
    "rag:reindex": "cd rag && node index.js --force",
    "rag:clean": "cd rag && npm run clean"
  }
}
